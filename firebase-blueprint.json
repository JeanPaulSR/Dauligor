{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "pronouns": { "type": "string", "description": "User's preferred pronouns" },
        "bio": { "type": "string", "description": "User's short biography" },
        "avatarUrl": { "type": "string", "description": "URL to user's profile picture" },
        "theme": { "type": "string", "enum": ["light", "dark", "parchment"], "default": "parchment" },
        "accentColor": { "type": "string", "description": "Hex code for the user's chosen highlight color" },
        "role": { "type": "string", "enum": ["admin", "co-dm", "lore-writer", "trusted-player", "user"] },
        "campaignIds": { "type": "array", "items": { "type": "string" }, "description": "List of campaign IDs the user is part of" },
        "activeCampaignId": { "type": "string", "description": "The currently selected campaign ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "role"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A DnD campaign that users can be assigned to.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "dmId": { "type": "string", "description": "UID of the DM (Admin)" },
        "eraId": { "type": "string", "description": "ID of the Era this campaign belongs to" },
        "playerIds": { "type": "array", "items": { "type": "string" }, "description": "List of player UIDs assigned to this campaign" },
        "recommendedLoreId": { "type": "string", "description": "ID of the recommended lore article for this campaign" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "dmId"]
    },
    "Era": {
      "title": "Era",
      "description": "A period of time in the world's history.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number", "description": "Chronological order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "LorePage": {
      "title": "Lore Page",
      "description": "A wiki-style page for world-building lore.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string", "description": "Short summary for previews" },
        "content": { "type": "string", "description": "Main markdown content" },
        "category": { "type": "string", "enum": ["generic", "building", "character", "country", "military", "deity", "geography", "item", "organization", "religion", "species", "vehicle", "settlement", "condition", "conflict", "document", "culture", "language", "material", "formation", "myth", "law", "plot", "profession", "prose", "title", "spell", "technology", "tradition", "session"] },
        "status": { "type": "string", "enum": ["draft", "published"], "default": "published" },
        "imageUrl": { "type": "string" },
        "parentPageId": { "type": "string", "description": "ID of the parent article for hierarchy" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "metadata": {
          "type": "object",
          "description": "Category-specific structured data",
          "properties": {
            "age": { "type": "string" },
            "race": { "type": "string" },
            "alignment": { "type": "string" },
            "occupation": { "type": "string" },
            "lifeStatus": { "type": "string", "description": "Alive/Dead/etc" },
            "gender": { "type": "string" },
            "pronouns": { "type": "string" },
            "birthDate": { "type": "string" },
            "deathDate": { "type": "string" },
            "locationType": { "type": "string" },
            "population": { "type": "string" },
            "climate": { "type": "string" },
            "ruler": { "type": "string" },
            "foundingDate": { "type": "string" },
            "parentLocation": { "type": "string" },
            "owningOrganization": { "type": "string" },
            "domains": { "type": "string" },
            "holySymbol": { "type": "string" },
            "motto": { "type": "string" },
            "headquarters": { "type": "string" },
            "leader": { "type": "string" }
          }
        },
        "mapCoordinates": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "authorId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "status"]
    },
    "LoreSecret": {
      "title": "Lore Secret",
      "description": "A secret revealed to specific campaigns within linked Eras",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "eraIds": { "type": "array", "items": { "type": "string" }, "description": "Eras this secret is relevant to" },
        "revealedCampaignIds": { "type": "array", "items": { "type": "string" }, "description": "Campaigns this secret has been revealed to" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "eraIds", "revealedCampaignIds"]
    },
    "LoreDMNotes": {
      "title": "Lore DM Notes",
      "description": "Private notes for DMs only",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content"]
    },
    "Source": {
      "title": "Source",
      "description": "A source book or document for content.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string", "description": "Markdown description of the source" },
        "url": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "tags": { 
          "type": "array", 
          "items": { 
            "type": "string", 
            "enum": ["Bestiary", "Classes", "Items", "Spells", "Feats"] 
          } 
        },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description"]
    },
    "SpellcastingScaling": {
      "title": "Spellcasting Scaling",
      "description": "Reusable spell slot and cantrip progression tables.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "levels": {
          "type": "object",
          "description": "Keyed by level 1-20",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "cantrips": { "type": "number" },
              "slots": { "type": "array", "items": { "type": "number" } }
            }
          }
        }
      },
      "required": ["name", "levels"]
    },
    "Class": {
      "title": "Class",
      "description": "A character class definition.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sourceId": { "type": "string" },
        "hitDie": { "type": "number" },
        "savingThrows": { "type": "array", "items": { "type": "string" } },
        "proficiencies": {
          "type": "object",
          "properties": {
            "armor": { "type": "string" },
            "weapons": { "type": "string" },
            "tools": { 
              "type": "object",
              "properties": {
                "choiceCount": { "type": "number" },
                "optionIds": { "type": "array", "items": { "type": "string" } },
                "fixedIds": { "type": "array", "items": { "type": "string" } }
              }
            },
            "skills": { 
              "type": "object",
              "properties": {
                "choiceCount": { "type": "number" },
                "optionIds": { "type": "array", "items": { "type": "string" } },
                "fixedIds": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "startingEquipment": { "type": "string" },
        "multiclassing": { "type": "string" },
        "imageUrl": { "type": "string" },
        "identifier": { "type": "string" },
        "subclassTitle": { "type": "string", "description": "Collective name for subclasses (e.g. Primal Path)" },
        "spellcastingId": { "type": "string" }
      },
      "required": ["name", "sourceId"]
    },
    "Subclass": {
      "title": "Subclass",
      "description": "A class specialization.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "identifier": { "type": "string" },
        "classIdentifier": { "type": "string" },
        "imageUrl": { "type": "string" },
        "classId": { "type": "string" },
        "sourceId": { "type": "string" },
        "description": { "type": "string" },
        "spellcasting": {
          "type": "object",
          "properties": {
            "hasSpellcasting": { "type": "boolean" },
            "description": { "type": "string" },
            "level": { "type": "number" },
            "ability": { "type": "string" },
            "type": { "type": "string" },
            "progressionId": { "type": "string" },
            "altProgressionId": { "type": "string" },
            "spellsKnownId": { "type": "string" },
            "spellsKnownFormula": { "type": "string" }
          }
        },
        "tagIds": { "type": "array", "items": { "type": "string" } },
        "uniqueOptionGroupIds": { "type": "array", "items": { "type": "string" } },
        "uniqueOptionMappings": { "type": "array", "items": { "type": "object" } },
        "excludedOptionIds": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "classId", "sourceId"]
    },
    "Feature": {
      "title": "Feature",
      "description": "A class or subclass feature.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "level": { "type": "number" },
        "parentId": { "type": "string" },
        "parentType": { "type": "string", "enum": ["class", "subclass"] },
        "isSubclassFeature": { "type": "boolean" },
        "quantityColumnId": { "type": "string", "description": "Linked Scaling Column for quantity (e.g. number of uses)" },
        "scalingColumnId": { "type": "string", "description": "Linked Scaling Column for scaling (e.g. damage die)" },
        "uniqueOptionGroupIds": { "type": "array", "items": { "type": "string" }, "description": "Modular choices attached to this feature" }
      },
      "required": ["name", "level", "parentId", "parentType"]
    },
    "ScalingColumn": {
      "title": "Scaling Column",
      "description": "Custom columns for the class table (e.g. Sorcery Points).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parentId": { "type": "string" },
        "parentType": { "type": "string", "enum": ["class", "subclass"] },
        "values": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["name", "parentId", "parentType", "values"]
    },
    "Spell": {
      "title": "Spell",
      "description": "A magic spell.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "level": { "type": "number" },
        "school": { "type": "string" },
        "sourceId": { "type": "string" },
        "description": { "type": "string" },
        "classIds": { "type": "array", "items": { "type": "string" } },
        "subclassIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "level", "sourceId"]
    },
    "UniqueOptionGroup": {
      "title": "Unique Option Group",
      "description": "A collection of modular choices like 'Eldritch Invocations'.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sourceId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sourceId"]
    },
    "UniqueOptionItem": {
      "title": "Unique Option Item",
      "description": "An individual choice within a group, like 'Agonizing Blast'.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "groupId": { "type": "string" },
        "sourceId": { "type": "string" },
        "page": { "type": "string" },
        "levelPrerequisite": { "type": "number" },
        "stringPrerequisite": { "type": "string" },
        "description": { "type": "string" },
        "isRepeatable": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "groupId", "sourceId"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A game skill like Athletics or Stealth.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "identifier": { "type": "string", "description": "Semantic slug" },
        "foundryAlias": { "type": "string", "description": "3-letter alias for FoundryVTT" },
        "ability": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
        "source": { "type": "string", "description": "Source book" },
        "page": { "type": "number", "description": "Page number in source" },
        "basicRules": { "type": "boolean", "description": "Whether it's part of the basic rules" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ability"]
    },
    "Tool": {
      "title": "Tool",
      "description": "A game tool like Thieves' Tools or a Lute.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "identifier": { "type": "string" },
        "foundryAlias": { "type": "string" },
        "category": { "type": "string" },
        "ability": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
        "source": { "type": "string" },
        "page": { "type": "number" },
        "basicRules": { "type": "boolean" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category"]
    },
    "Weapon": {
      "title": "Weapon",
      "description": "A weapon proficiency.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "identifier": { "type": "string" },
        "foundryAlias": { "type": "string" },
        "category": { "type": "string" },
        "ability": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
        "source": { "type": "string" },
        "page": { "type": "number" },
        "basicRules": { "type": "boolean" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category"]
    },
    "Armor": {
      "title": "Armor",
      "description": "An armor proficiency.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "identifier": { "type": "string" },
        "foundryAlias": { "type": "string" },
        "category": { "type": "string" },
        "ability": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
        "source": { "type": "string" },
        "page": { "type": "number" },
        "basicRules": { "type": "boolean" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category"]
    },
    "Character": {
      "title": "Character",
      "description": "A player character.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "info": { "type": "object" },
        "raceId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "backgroundId": { "type": "string" },
        "campaignId": { "type": "string" },
        "classId": { "type": "string" },
        "subclassId": { "type": "string" },
        "level": { "type": "number", "default": 1 },
        "isLevelLocked": { "type": "boolean", "default": false },
        "hp": {
          "type": "object",
          "properties": {
            "current": { "type": "number", "default": 10 },
            "max": { "type": "number", "default": 10 },
            "temp": { "type": "number", "default": 0 }
          }
        },
        "hitDie": {
          "type": "object",
          "properties": {
            "current": { "type": "number", "default": 1 },
            "max": { "type": "number", "default": 1 },
            "type": { "type": "string", "description": "e.g. d10" }
          }
        },
        "spellPoints": {
          "type": "object",
          "properties": {
            "current": { "type": "number", "default": 0 },
            "max": { "type": "number", "default": 0 }
          }
        },
        "ac": { "type": "number", "default": 10 },
        "initiative": { "type": "number", "default": 0 },
        "speed": { "type": "number", "default": 30 },
        "proficiencyBonus": { "type": "number", "default": 2 },
        "savingThrows": { "type": "array", "items": { "type": "string" }, "description": "List of proficient ability scores" },
        "proficientSkills": { "type": "array", "items": { "type": "string" } },
        "expertiseSkills": { "type": "array", "items": { "type": "string" } },
        "resistances": { "type": "array", "items": { "type": "string" } },
        "immunities": { "type": "array", "items": { "type": "string" } },
        "vulnerabilities": { "type": "array", "items": { "type": "string" } },
        "armorProficiencies": { "type": "array", "items": { "type": "string" } },
        "weaponProficiencies": { "type": "array", "items": { "type": "string" } },
        "toolProficiencies": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "senses": {
          "type": "object",
          "properties": {
            "passivePerception": { "type": "number", "default": 10 },
            "passiveInvestigation": { "type": "number", "default": 10 },
            "passiveInsight": { "type": "number", "default": 10 },
            "additional": { "type": "string" }
          }
        },
        "raceData": {
          "type": "object",
          "properties": {
            "creatureType": { "type": "string" },
            "size": { "type": "string" }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "method": { "type": "string", "enum": ["point-buy", "standard", "manual"] },
            "base": {
              "type": "object",
              "properties": {
                "STR": { "type": "number" },
                "DEX": { "type": "number" },
                "CON": { "type": "number" },
                "INT": { "type": "number" },
                "WIS": { "type": "number" },
                "CHA": { "type": "number" }
              }
            }
          }
        },
        "bookmarks": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/lore/{pageId}": {
      "schema": "LorePage",
      "description": "Lore wiki pages."
    },
    "/lore/{pageId}/secrets/{secretId}": {
      "schema": "LoreSecret",
      "description": "Secrets revealed to specific campaigns."
    },
    "/lore/{pageId}/dmData/notes": {
      "schema": "LoreDMNotes",
      "description": "Private notes for DMs only."
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Campaign documents."
    },
    "/eras/{eraId}": {
      "schema": "Era",
      "description": "World eras."
    },
    "/sources/{sourceId}": {
      "schema": "Source",
      "description": "Content source books."
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Character classes."
    },
    "/subclasses/{subclassId}": {
      "schema": "Subclass",
      "description": "Class specializations."
    },
    "/features/{featureId}": {
      "schema": "Feature",
      "description": "Class and subclass features."
    },
    "/scalingColumns/{columnId}": {
      "schema": "ScalingColumn",
      "description": "Custom class table columns."
    },
    "/spells/{spellId}": {
      "schema": "Spell",
      "description": "Magic spells."
    },
    "/uniqueOptionGroups/{groupId}": {
      "schema": "UniqueOptionGroup",
      "description": "Categories of modular choices (e.g. Invocations)."
    },
    "/uniqueOptionItems/{itemId}": {
      "schema": "UniqueOptionItem",
      "description": "Individual modular choices."
    },
    "/spellcastingScalings/{scalingId}": {
      "schema": "SpellcastingScaling",
      "description": "Spell slot progression tables."
    },
    "/skills/{skillId}": {
      "schema": "Skill",
      "description": "Standardized skills."
    },
    "/tools/{toolId}": {
      "schema": "Tool",
      "description": "Standardized tools."
    },
    "/weapons/{weaponId}": {
      "schema": "Weapon",
      "description": "Standardized weapons."
    },
    "/armor/{armorId}": {
      "schema": "Armor",
      "description": "Standardized armor."
    },
    "/characters/{characterId}": {
      "schema": "Character",
      "description": "Player characters."
    }
  }
}
