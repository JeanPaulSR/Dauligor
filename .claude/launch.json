{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Express + Vite (dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:nowatch"],
      "port": 3000
    },
    {
      "name": "Cloudflare Worker (wrangler dev)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd worker && npx wrangler dev"],
      "port": 8787
    },
    {
      "name": "Docs (compendium-editors)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "docs/architecture/compendium-editors", "-p", "5500", "-c-1"],
      "port": 5500
    },
    {
      "name": "manual-uploads",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/dev-manual-uploads.mjs"],
      "port": 3003
    }
  ]
}
