rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 5 * 1024 * 1024;
    }

    // User avatars — user can only upload to their own folder
    match /images/users/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidImage();
    }

    // Class artwork (admin-only in UI)
    match /images/classes/{classId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Subclass artwork (admin-only in UI)
    match /images/subclasses/{subclassId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Lore article images (staff-only in UI)
    match /images/lore/{articleId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Source book cover images (staff-only in UI)
    match /images/sources/{sourceId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Character portrait images (owner in UI)
    match /images/characters/{characterId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
