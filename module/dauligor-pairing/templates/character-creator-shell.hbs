<section class="dauligor-character-creator__shell">
  {{!--
    Stepper rail across the top. Each step is a clickable chip — the
    wizard allows free back-and-forth, so every step stays reachable.
    Rendered by DauligorCharacterCreatorApp._renderStepper().
  --}}
  <header class="dauligor-character-creator__stepper" data-region="stepper"></header>

  {{!--
    Step body. _renderBody() swaps the inner markup based on the current
    step (abilities / background / race / class / items / review).
  --}}
  <div class="dauligor-character-creator__body" data-region="body"></div>

  {{!--
    Footer — status text on the left, Back / Next (or Finish on the
    review step) on the right. Rendered by _renderFooter().
  --}}
  <footer class="dauligor-character-creator__footer" data-region="footer"></footer>
</section>
