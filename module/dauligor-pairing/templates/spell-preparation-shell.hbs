<section class="dauligor-spell-manager dauligor-spell-manager--picker">
  <div class="dauligor-spell-manager__layout-grid">
    {{!--
      Left sidebar — classes on top (compact list, line-separated), favourites below
      filling the remaining vertical space. Favourites has its own search + filter
      button (which opens the shared modal scoped to favourites state).
    --}}
    <aside class="dauligor-spell-manager__sidebar">
      <div class="dauligor-spell-manager__sidebar-classes" data-region="rail"></div>
      <div class="dauligor-spell-manager__sidebar-favorites" data-region="favorites"></div>
    </aside>

    {{!--
      Middle column — pool. Meta strip (prep-type-aware counters), toolbar
      (search + filter button + On Sheet toggle), then the level-grouped
      spell list.
    --}}
    <section class="dauligor-spell-manager__pool-column">
      <div class="dauligor-spell-manager__meta" data-region="meta"></div>
      <div class="dauligor-spell-manager__pool-toolbar" data-region="toolbar"></div>
      <div class="dauligor-spell-manager__pool-scroll" data-region="pool"></div>
    </section>

    {{!--
      Right column — detail. Stays minimum-width but absorbs leftover space
      when the window resizes (vs. the legacy layout where the middle column
      grew on resize). See the CSS grid-template-columns rule.
    --}}
    <aside class="dauligor-spell-manager__detail" data-region="detail"></aside>
  </div>

  {{!--
    Footer — action buttons. Always rendered; content swaps based on
    selected class's prep type (Spellbook adds a fourth Add to Spellbook
    button) and the selected spell's current sheetMode.
  --}}
  <footer class="dauligor-spell-manager__footer" data-region="footer"></footer>

  {{!--
    Filter modal overlay — single instance, opens for either the pool
    or the favourites filter set. Hidden by default; the manager flips
    `data-region="filter-modal"` visibility via its own `hidden` attr.
  --}}
  <div class="dauligor-spell-manager__filter-modal-host" data-region="filter-modal" hidden></div>
</section>
