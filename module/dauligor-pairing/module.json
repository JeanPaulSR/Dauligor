{
  "id": "dauligor-pairing",
  "title": "Dauligor Pairing",
  "description": "Foundry VTT v13 bridge module for Dauligor research, a Foundry-side importer window, class import browsing, research bundles, and test imports.",
  "version": "0.5.60",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "Jean"
    }
  ],
  "socket": true,
  "system": [
    "dnd5e"
  ],
  "relationships": {
    "requires": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "compatibility": {
          "verified": "1.13.4.0"
        }
      },
      {
        "id": "socketlib",
        "type": "module",
        "compatibility": {
          "verified": "1.1.3"
        }
      }
    ]
  },
  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    "styles/tokens.css",
    "styles/base.css",
    "styles/importer-wizard.css",
    "styles/class-browser.css",
    "styles/option-picker.css",
    "styles/asi.css",
    "styles/overview.css",
    "styles/spell-manager.css",
    "styles/feature-manager.css",
    "styles/section-filter.css",
    "styles/feat-browser.css",
    "styles/character-sheet.css",
    "styles/directory-tools.css",
    "styles/gm-console.css",
    "styles/responsive.css"
  ]
}
