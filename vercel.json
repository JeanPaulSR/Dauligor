{
  "rewrites": [
    {
      "source": "/api/module/(.*)",
      "destination": "/api/module"
    },
    {
      "source": "/api/module",
      "destination": "/api/module"
    },
    {
      "source": "/api/me",
      "destination": "/api/me/__root"
    },
    {
      "source": "/api/lore",
      "destination": "/api/lore/__root"
    },
    {
      "source": "/api/campaigns",
      "destination": "/api/campaigns/__root"
    },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
